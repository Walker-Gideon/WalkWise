rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profile rules
    // Only the authenticated user can read or write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Flashcard rules
    // A user can only create a flashcard if it belongs to them.
    // A user can only read, update, or delete a flashcard that belongs to them.
    match /flashcards/{flashcardId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Schedule rules
    // A user can only create a session if it belongs to them.
    // A user can only read, update, or delete a session that belongs to them.
    match /schedule/{sessionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Notes rules
    // A user can only create a note if it belongs to them.
    // A user can only read, update, or delete a note that belongs to them.
    match /notes/{noteId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
